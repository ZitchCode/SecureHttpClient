<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>SecureHttpClient</id>
    <version>$version$</version>
    <title>SecureHttpClient</title>
    <authors>tranb3r</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/ZitchCode/SecureHttpClient</projectUrl>
    <description>Cross-platform HttpClientHandler with additional security features (certificate pinning, TLS1.2+, client certificates)</description>
    <releaseNotes>https://github.com/ZitchCode/SecureHttpClient/releases</releaseNotes>
    <copyright>Copyright 2026 ZitchCode</copyright>
    <tags>.net dotnet-maui xamarin dotnet maui cross-platform ios android windows httpclient security certificate pinning</tags>
    <repository type="git" url="https://github.com/ZitchCode/SecureHttpClient.git" />
	<readme>README.md</readme>
    <icon>icon.png</icon>	
    <dependencies>
      <group targetFramework="$NetTfm$">
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="$MicrosoftExtensionsLoggingAbstractionsVersion$" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="$AndroidTfm$">
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="$MicrosoftExtensionsLoggingAbstractionsVersion$" exclude="Build,Analyzers" />
        <dependency id="Square.OkHttp3.Android" version="$SquareOkHttp3AndroidVersion$" exclude="Build,Analyzers" />
        <dependency id="Square.OkIO" version="$SquareOkIOVersion$" exclude="Build,Analyzers" />
        <dependency id="Xamarin.Brotli.Dec" version="$XamarinBrotliDecVersion$" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="$IosTfm$">
        <dependency id="Microsoft.Extensions.Logging.Abstractions" version="$MicrosoftExtensionsLoggingAbstractionsVersion$" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="SecureHttpClient\bin\Release\$NetTfm$\SecureHttpClient.dll" target="lib\$NetTfm$" />
    <file src="SecureHttpClient\bin\Release\$NetTfm$\SecureHttpClient.xml" target="lib\$NetTfm$" />
    <file src="SecureHttpClient\bin\Release\$NetTfm$\SecureHttpClient.pdb" target="lib\$NetTfm$" />
    <file src="SecureHttpClient\bin\Release\$AndroidTfm$\SecureHttpClient.dll" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient\bin\Release\$AndroidTfm$\SecureHttpClient.xml" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient\bin\Release\$AndroidTfm$\SecureHttpClient.pdb" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient.OkHttp\bin\Release\$AndroidTfm$\SecureHttpClient.OkHttp.dll" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient.OkHttp\bin\Release\$AndroidTfm$\SecureHttpClient.OkHttp.xml" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient.OkHttp\bin\Release\$AndroidTfm$\SecureHttpClient.OkHttp.aar" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient.OkHttp\bin\Release\$AndroidTfm$\SecureHttpClient.OkHttp.pdb" target="lib\$AndroidTfm$" />
    <file src="SecureHttpClient\bin\Release\$IosTfm$\SecureHttpClient.dll" target="lib\$IosTfm$" />
    <file src="SecureHttpClient\bin\Release\$IosTfm$\SecureHttpClient.xml" target="lib\$IosTfm$" />
    <file src="SecureHttpClient\bin\Release\$IosTfm$\SecureHttpClient.pdb" target="lib\$IosTfm$" />
	<file src="README.md" target="." />
    <file src="icon.png" target="." />
  </files>
</package>
